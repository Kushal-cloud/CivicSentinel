APP_ENV=local
DATABASE_URL=postgresql+asyncpg://civic:civic@localhost:5432/civic
JWT_SECRET=change_me_local
ACCESS_TOKEN_EXPIRE_MINUTES=1440
STORAGE_DIR=/tmp/civicsentinel_uploads
MAX_UPLOAD_BYTES=8000000
OSM_USER_AGENT=CivicSentinel/1.0 (contact: example@example.com)
ESCALATION_HOURS=48

# Optional SMTP configuration for submission notifications
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# AI model API key
GEMINI_API_KEY=

# Optional model paths
YOLO_WEIGHTS_PATH=models/yolov8n.pt
YOLO_CONF_THRESHOLD=0.25

# Optional NLP model
NLP_MODEL_NAME=google/flan-t5-small

# Default languages supported by the template/prompting system
DEFAULT_LANGUAGES=en,hi,bn,ta,te,ml,mr,kn,gu,pa,ur

# ── Railway Deployment ───────────────────────────────────────────────────────
# BACKEND_URL: Set this on the Railway *frontend* service.
# It should be the public URL of your Railway backend service.
# Example: https://civicsentinel-backend.up.railway.app
# The Nginx reverse proxy uses this to forward /api/* requests.
BACKEND_URL=https://your-backend.up.railway.app

